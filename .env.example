# Kiwi.com Tequila API key for live flight prices.
# Get one at https://tequila.kiwi.com (free tier available for personal use).
# Leave unset to run the server in DEMO mode.
TEQUILA_API_KEY=

# Optional: where to store the local SQLite database.
# Defaults to flights.db in the project root.
# FLIGHT_DB_PATH=/absolute/path/to/flights.db
